record(longout, "$(P)MPS:invert") {
    field(DESC, "Bitmap of MPS inputs to invert")
    field(DTYP, "FEED Register Write")
    field(OUT,  "@name=$(NAME) reg=MPS:invert")
}
record(longout, "$(P)MPS:forceTrip") {
    field(DESC, "Bitmap of MPS outputs to trip")
    field(DTYP, "FEED Register Write")
    field(OUT,  "@name=$(NAME) reg=MPS:forceTrip")
}
