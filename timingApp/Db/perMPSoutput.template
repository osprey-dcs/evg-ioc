# initialize :$(N)array registers Con connect PHAS=-1
record(longin, "$(P)M:$(N)_") {
    field(DTYP, "FEED On Connect")
    field(INP , "@name=$(NAME)")
    field(SCAN, "I/O Intr")
    field(PHAS, "-1") # prepare for Flush in perFPGA.template
    field(FLNK, "$(P)M:$(N)F_")
}
record(fanout, "$(P)M:$(N)F_") {
    field(LNK5, "$(P)MPS:chkInputs:$(N)")
    field(LNK6, "$(P)MPS:goodState:$(N)")
}
record(longout, "$(P)MPS:chkInputs:$(N)") {
    field(DTYP, "FEED Register Write")
    field(OUT,  "@name=$(NAME) reg=MPS:check:$(N)")
    info(autosaveFields_pass0, "VAL")
}
record(longout, "$(P)MPS:goodState:$(N)") {
    field(DTYP, "FEED Register Write")
    field(OUT,  "@name=$(NAME) reg=MPS:goodState:$(N)")
    info(autosaveFields_pass0, "VAL")
}
record(longin, "$(P)MPS:status:$(N)") {
    field(DTYP, "FEED Register Read")
    field(INP,  "@name=$(NAME) reg=MPS:status:$(N)")
    field(SCAN, "1 second")
    field(FLNK, "$(P)MPS:status:$(N):trp")
}
record(bi, "$(P)MPS:status:$(N):trp") {
    field(DESC, "Latched state")
    field(DTYP, "Raw Soft Channel")
    field(INP , "$(P)MPS:status:$(N) MS")
    field(MASK, "0x1")
    field(ZNAM, "Normal")
    field(ONAM, "Tripped")
    field(OSV , "MAJOR")
    field(FLNK, "$(P)MPS:status:$(N):cur")
}
record(bi, "$(P)MPS:status:$(N):cur") {
    field(DESC, "Instant state")
    field(DTYP, "Raw Soft Channel")
    field(INP , "$(P)MPS:status:$(N) MS")
    field(MASK, "0x2")
    field(ZNAM, "Ok")
    field(ONAM, "Fault")
    field(OSV , "MAJOR")
    field(FLNK, "$(P)MPS:chkTrip:$(N)_")
}
record(calcout, "$(P)MPS:chkTrip:$(N)_") {
    field(DESC, "Trigger first-fault readbacks")
    field(INPA, "$(P)MPS:status:$(N) MS")
    field(CALC, "A&1")
    field(OOPT, "Transition To Non-zero")
    field(OUT,  "$(P)MPS:firstRBK:$(N)_.PROC")
}
record(fanout, "$(P)MPS:firstRBK:$(N)_") {
    field(LNK4, "$(P)MPS:firstInputs:$(N)")
    field(LNK5, "$(P)MPS:firstSeconds:$(N)")
    field(LNK6, "$(P)MPS:firstTicks:$(N)")
}
record(longin, "$(P)MPS:firstInputs:$(N)") {
    field(DTYP, "FEED Register Read")
    field(INP,  "@name=$(NAME) reg=MPS:firstFault:$(N)")
}
record(longin, "$(P)MPS:firstSeconds:$(N)") {
    field(DTYP, "FEED Register Read")
    field(INP,  "@name=$(NAME) reg=MPS:faultSeconds:$(N)")
}
record(longin, "$(P)MPS:firstTicks:$(N)") {
    field(DTYP, "FEED Register Read")
    field(INP,  "@name=$(NAME) reg=MPS:faultTicks:$(N)")
}
